}
.card-meta .author { font-weight: 600; color: var(--ink); }
a.card { text-decoration: none; color: inherit; }

/* ── THREE COL GRID ── */
.three-col {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--col-gap);
  margin-top: 1rem;
}
.two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--col-gap);
  margin-top: 1rem;
}

/* ── SIDEBAR WIDGET ── */
.sidebar-widget {
  background: #fff;
  border: 1px solid var(--rule);
