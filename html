}
.nav-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
}
nav a {
  font-family: 'DM Sans', sans-serif;
  font-weight: 600;
