nav a.active { border-bottom-color: var(--accent); }

/* pill badge on nav item */
nav a .badge {
  background: var(--accent);
  color: #fff;
  font-size: 0.6rem;
  font-weight: 600;
  padding: 0.1em 0.4em;
  border-radius: 3px;
  letter-spacing: 0.04em;
  vertical-align: middle;
}

/* ── BREAKING NEWS TICKER ── */
.ticker-wrap {
  background: var(--accent);
  color: #fff;
  display: flex;
  align-items: center;
  overflow: hidden;
  height: 2.2rem;
  font-family: 'DM Sans', sans-serif;
